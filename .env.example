# Copy this file to .env and edit the values for your local machine.
# The real .env file is ignored by Git.

# OpenAI-compatible providers read the variable named by llm.api_key_env
# in projects/<project>/config/project.yaml.
OPENAI_API_KEY=

# Optional aliases for local or proxied providers.
LM_STUDIO_API_KEY=
OLLAMA_API_KEY=
VLLM_API_KEY=

# Optional: point the CLI at a different environment file.
# ACADEMIC_PAPER_CLI_ENV_FILE=/absolute/path/to/another.env
